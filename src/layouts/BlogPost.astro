---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags = [] } = Astro.props;

const categoryTitles: Record<string, string> = {
	proyectos: 'Proyectos',
	divulgacion: 'Divulgación',
	miscelanea: 'Miscelánea',
	'mi-pc': 'Mi PC',
	configuraciones: 'Configuraciones',
	homelab: 'HomeLab',
};
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
				max-width: 1020px;
				margin: 0 auto 2rem auto;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				aspect-ratio: 21 / 9;
				object-fit: cover;
				object-position: center;
				max-height: 340px;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--text-color);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: left;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.post-metadata {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: flex-start;
				gap: 0.75rem;
				margin-top: 0.5rem;
				margin-bottom: 1.5rem;
			}
			.category-badge {
				display: inline-block;
				padding: 0.25rem 0.75rem;
				font-size: 0.8rem;
				font-weight: 700;
				text-transform: uppercase;
				border-radius: 6px;
				background: rgba(var(--gray-light), 50%);
				color: var(--text-color);
				border: 1px solid rgba(var(--gray), 15%);
				text-decoration: none;
				transition: background-color 0.2s, border-color 0.2s;
			}
			.category-badge:hover {
				background: rgba(var(--gray-light), 80%);
			}
			.category-badge.proyectos {
				background: rgba(59, 130, 246, 15%);
				color: #3b82f6;
				border-color: rgba(59, 130, 246, 30%);
			}
			.category-badge.proyectos:hover {
				background: rgba(59, 130, 246, 25%);
			}
			.category-badge.divulgacion {
				background: rgba(16, 185, 129, 15%);
				color: #10b981;
				border-color: rgba(16, 185, 129, 30%);
			}
			.category-badge.divulgacion:hover {
				background: rgba(16, 185, 129, 25%);
			}
			.category-badge.miscelanea {
				background: rgba(107, 114, 128, 15%);
				color: #6b7280;
				border-color: rgba(107, 114, 128, 30%);
			}
			.category-badge.miscelanea:hover {
				background: rgba(107, 114, 128, 25%);
			}
			.category-badge.mi-pc {
				background: rgba(245, 158, 11, 15%);
				color: #f59e0b;
				border-color: rgba(245, 158, 11, 30%);
			}
			.category-badge.mi-pc:hover {
				background: rgba(245, 158, 11, 25%);
			}
			.category-badge.configuraciones {
				background: rgba(139, 92, 246, 15%);
				color: #8b5cf6;
				border-color: rgba(139, 92, 246, 30%);
			}
			.category-badge.configuraciones:hover {
				background: rgba(139, 92, 246, 25%);
			}
			.category-badge.homelab {
				background: rgba(20, 184, 166, 15%);
				color: #14b8a6;
				border-color: rgba(20, 184, 166, 30%);
			}
			.category-badge.homelab:hover {
				background: rgba(20, 184, 166, 25%);
			}
			.tag-badge {
				font-size: 0.85rem;
				color: var(--accent);
				font-weight: 500;
				text-decoration: none;
			}
			.tag-badge:hover {
				text-decoration: underline;
				color: var(--accent-dark);
			}

			/* Estilos para Diagramas de Mermaid */
			.mermaid {
				width: 100%;
				background: transparent !important;
				border: none !important;
				border-radius: 0 !important;
				padding: 0 !important;
				box-shadow: none !important;
				display: flex;
				justify-content: center;
				align-items: center;
				overflow-x: auto;
				margin: 2.5rem 0;
			}
			.mermaid svg {
				max-width: 100% !important;
				height: auto !important;
				min-width: 600px; /* Evita que el diagrama se encoja a tamaños ilegibles en pantallas medianas/pequeñas */
			}

			/* Breakout panorámico para pantallas grandes (alineado con la imagen de portada de 1020px) */
			@media (min-width: 1060px) {
				.mermaid {
					width: 1020px !important;
					max-width: 1020px !important;
					margin-left: calc(50% - 510px) !important;
					margin-right: calc(50% - 510px) !important;
					padding: 0 !important;
				}
				.mermaid svg {
					min-width: 800px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<div class="post-metadata">
							{category && (
								<a href={`/blog/category/${category}`} class={`category-badge ${category}`}>
									{categoryTitles[category] || category}
								</a>
							)}
							{tags.map((tag) => (
								<a href={`/blog/tag/${tag}`} class="tag-badge">#{tag}</a>
							))}
						</div>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			import mermaid from 'mermaid';
			
			// Inicializar mermaid para buscar y renderizar elementos con clase "mermaid"
			mermaid.initialize({
				startOnLoad: true,
				theme: 'dark',
			});
		</script>
	</body>
</html>
