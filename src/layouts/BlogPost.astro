---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags = [] } = Astro.props;

const categoryTitles: Record<string, string> = {
	proyectos: 'Proyectos',
	divulgacion: 'Divulgación',
	miscelanea: 'Miscelánea',
	'mi-pc': 'Mi PC',
	configuraciones: 'Configuraciones',
	homelab: 'HomeLab',
};
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
				max-width: 1020px;
				margin: 0 auto 2rem auto;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				aspect-ratio: 21 / 9;
				object-fit: cover;
				object-position: center;
				max-height: 340px;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--text-color);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: left;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.post-metadata {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: flex-start;
				gap: 0.75rem;
				margin-top: 0.5rem;
				margin-bottom: 1.5rem;
			}
			.category-badge {
				display: inline-block;
				padding: 0.25rem 0.75rem;
				font-size: 0.8rem;
				font-weight: 700;
				text-transform: uppercase;
				border-radius: 6px;
				background: rgba(var(--gray-light), 50%);
				color: var(--text-color);
				border: 1px solid rgba(var(--gray), 15%);
				text-decoration: none;
				transition: background-color 0.2s, border-color 0.2s;
			}
			.category-badge:hover {
				background: rgba(var(--gray-light), 80%);
			}
			.category-badge.proyectos {
				background: rgba(59, 130, 246, 15%);
				color: #3b82f6;
				border-color: rgba(59, 130, 246, 30%);
			}
			.category-badge.proyectos:hover {
				background: rgba(59, 130, 246, 25%);
			}
			.category-badge.divulgacion {
				background: rgba(16, 185, 129, 15%);
				color: #10b981;
				border-color: rgba(16, 185, 129, 30%);
			}
			.category-badge.divulgacion:hover {
				background: rgba(16, 185, 129, 25%);
			}
			.category-badge.miscelanea {
				background: rgba(107, 114, 128, 15%);
				color: #6b7280;
				border-color: rgba(107, 114, 128, 30%);
			}
			.category-badge.miscelanea:hover {
				background: rgba(107, 114, 128, 25%);
			}
			.category-badge.mi-pc {
				background: rgba(245, 158, 11, 15%);
				color: #f59e0b;
				border-color: rgba(245, 158, 11, 30%);
			}
			.category-badge.mi-pc:hover {
				background: rgba(245, 158, 11, 25%);
			}
			.category-badge.configuraciones {
				background: rgba(139, 92, 246, 15%);
				color: #8b5cf6;
				border-color: rgba(139, 92, 246, 30%);
			}
			.category-badge.configuraciones:hover {
				background: rgba(139, 92, 246, 25%);
			}
			.category-badge.homelab {
				background: rgba(20, 184, 166, 15%);
				color: #14b8a6;
				border-color: rgba(20, 184, 166, 30%);
			}
			.category-badge.homelab:hover {
				background: rgba(20, 184, 166, 25%);
			}
			.tag-badge {
				font-size: 0.85rem;
				color: var(--accent);
				font-weight: 500;
				text-decoration: none;
			}
			.tag-badge:hover {
				text-decoration: underline;
				color: var(--accent-dark);
			}

			/* Estilos para Diagramas de Mermaid */
			.mermaid {
				width: 100%;
				background: transparent !important;
				border: none !important;
				border-radius: 0 !important;
				padding: 0 !important;
				box-shadow: none !important;
				display: flex;
				justify-content: center;
				align-items: center;
				overflow-x: auto;
				margin: 2.5rem 0;
			}
			.mermaid svg {
				max-width: 100% !important;
				height: auto !important;
				min-width: 600px; /* Evita que el diagrama se encoja a tamaños ilegibles en pantallas medianas/pequeñas */
			}

			/* Breakout panorámico para pantallas grandes (alineado con la imagen de portada de 1020px) */
			@media (min-width: 1060px) {
				.mermaid {
					width: 1020px !important;
					max-width: 1020px !important;
					margin-left: calc(50% - 510px) !important;
					margin-right: calc(50% - 510px) !important;
					padding: 0 !important;
				}
				.mermaid svg {
					min-width: 800px;
				}
			}
		</style>
		<style is:global>
			/* Estilos de Comentarios (Completamente Planos, Transparentes y Globales) */
			.comments-divider {
				margin: 3.5rem 0 2rem 0;
				border: 0;
				border-top: 1px solid rgba(255, 255, 255, 0.1);
			}
			.comments-section {
				margin-top: 2rem;
			}
			.comments-section h3 {
				margin-bottom: 1.5rem;
				font-size: 1.5rem;
				color: var(--title-color);
			}
			.comments-list {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				margin-bottom: 2.5rem;
			}
			.no-comments {
				color: rgb(var(--gray));
				font-style: italic;
				margin-bottom: 1.5rem;
				font-size: 0.95rem;
			}
			.comment-item {
				background: transparent;
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
				padding-bottom: 1.25rem;
			}
			.comment-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 0.6rem;
			}
			.comment-author-info {
				display: flex;
				align-items: center;
				gap: 0.75rem;
			}
			.comment-avatar {
				width: 32px;
				height: 32px;
				background: #1e1e24;
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 0.85rem;
				font-weight: 700;
				color: var(--title-color);
			}
			.comment-author-name {
				font-weight: 600;
				color: var(--title-color);
				font-size: 0.95rem;
			}
			.comment-date {
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
			.comment-body {
				font-size: 0.95rem;
				line-height: 1.6;
				color: var(--text-color);
				padding-left: 2.5rem;
				word-break: break-word;
			}
			
			/* Formulario de Comentarios */
			.comment-form {
				background: transparent;
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 8px;
				padding: 1.5rem;
				margin-top: 3rem;
			}
			.comment-form h4 {
				margin-top: 0;
				margin-bottom: 1.25rem;
				font-size: 1.15rem;
				color: var(--title-color);
			}
			.form-group {
				margin-bottom: 1.25rem;
			}
			.form-group label {
				display: block;
				margin-bottom: 0.4rem;
				font-size: 0.85rem;
				font-weight: 600;
				color: var(--title-color);
			}
			.form-group input,
			.form-group textarea {
				width: 100%;
				background: #09090b;
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 6px;
				padding: 0.6rem 0.8rem;
				color: #ffffff;
				font-family: inherit;
				font-size: 0.95rem;
				transition: border-color 0.2s ease, outline 0.2s ease;
			}
			.form-group input:focus,
			.form-group textarea:focus {
				border-color: var(--accent);
				outline: 1px solid var(--accent);
			}
			.submit-btn {
				background: var(--accent);
				color: #ffffff;
				border: none;
				border-radius: 6px;
				padding: 0.7rem 1.25rem;
				font-size: 0.95rem;
				font-weight: 600;
				cursor: pointer;
				transition: background-color 0.2s ease;
			}
			.submit-btn:hover {
				background: var(--accent-dark);
			}
			.submit-btn:disabled {
				background: #27272a;
				color: #71717a;
				cursor: not-allowed;
			}
			.comment-message {
				margin-top: 1rem;
				font-size: 0.9rem;
				font-weight: 500;
			}
			.comment-message.success {
				color: #10b981;
			}
			.comment-message.error {
				color: #ef4444;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<div class="post-metadata">
							{category && (
								<a href={`/blog/category/${category}`} class={`category-badge ${category}`}>
									{categoryTitles[category] || category}
								</a>
							)}
							{tags.map((tag) => (
								<a href={`/blog/tag/${tag}`} class="tag-badge">#{tag}</a>
							))}
						</div>
						<hr />
					</div>
					<slot />

					<!-- Sección de Comentarios Anónimos -->
					<hr class="comments-divider" />
					<section class="comments-section" data-slug={Astro.params.slug}>
						<h3>Comentarios</h3>
						<div id="comments-list" class="comments-list">
							<!-- Populado dinámicamente -->
							<p class="no-comments">Cargando comentarios...</p>
						</div>

						<form id="comment-form" class="comment-form">
							<h4>Escribir un comentario anónimo</h4>
							<div class="form-group">
								<label for="comment-author">Nombre o Apodo (Opcional)</label>
								<input type="text" id="comment-author" placeholder="Anónimo" maxlength="50" autocomplete="off" />
							</div>
							<div class="form-group">
								<label for="comment-content">Mensaje</label>
								<textarea id="comment-content" required placeholder="Escribe tu comentario aquí..." maxlength="1000" rows="4"></textarea>
							</div>
							<button type="submit" id="submit-comment-btn" class="submit-btn">Enviar comentario</button>
							<div id="comment-message" class="comment-message"></div>
						</form>
					</section>
				</div>
			</article>
		</main>
		<Footer />
		<script>
			import mermaid from 'mermaid';
			
			// Inicializar mermaid para buscar y renderizar elementos con clase "mermaid"
			mermaid.initialize({
				startOnLoad: true,
				theme: 'dark',
			});

			// Lógica del sistema de comentarios anónimos
			const commentsSection = document.querySelector('.comments-section');
			if (commentsSection) {
				const slug = commentsSection.getAttribute('data-slug');
				const commentsList = document.getElementById('comments-list');
				const commentForm = document.getElementById('comment-form');
				const messageEl = document.getElementById('comment-message');
				const submitBtn = document.getElementById('submit-comment-btn') as HTMLButtonElement;

				// Cargar comentarios
				const loadComments = async () => {
					try {
						const res = await fetch(`/api/comments?slug=${encodeURIComponent(slug || '')}`);
						if (res.ok) {
							const comments = await res.json();
							renderComments(comments);
						} else {
							if (commentsList) commentsList.innerHTML = '<p class="no-comments">Error al cargar los comentarios.</p>';
						}
					} catch (e) {
						console.error('Error al cargar comentarios:', e);
						if (commentsList) commentsList.innerHTML = '<p class="no-comments">Error de conexión al cargar comentarios.</p>';
					}
				};

				// Renderizar comentarios
				const renderComments = (comments: any[]) => {
					if (!commentsList) return;
					if (comments.length === 0) {
						commentsList.innerHTML = '<p class="no-comments">No hay comentarios aún. ¡Sé el primero en comentar!</p>';
						return;
					}

					commentsList.innerHTML = comments
						.map((c) => {
							const date = new Date(c.created_at).toLocaleDateString('es-ES', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
								hour: '2-digit',
								minute: '2-digit',
							});
							const initials = c.author_name.substring(0, 2).toUpperCase() || 'AN';
							return `
								<div class="comment-item">
									<div class="comment-header">
										<div class="comment-author-info">
											<div class="comment-avatar">${initials}</div>
											<span class="comment-author-name">${c.author_name}</span>
										</div>
										<span class="comment-date">${date}</span>
									</div>
									<div class="comment-body">${c.content}</div>
								</div>
							`;
						})
						.join('');
				};

				// Escuchar envío del formulario de comentarios
				if (commentForm) {
					commentForm.addEventListener('submit', async (e) => {
						e.preventDefault();
						
						const authorEl = document.getElementById('comment-author') as HTMLInputElement;
						const contentEl = document.getElementById('comment-content') as HTMLTextAreaElement;

						if (!contentEl || contentEl.value.trim() === '') return;

						// Deshabilitar botón para evitar envíos múltiples
						if (submitBtn) {
							submitBtn.disabled = true;
							submitBtn.textContent = 'Enviando...';
						}
						if (messageEl) {
							messageEl.textContent = '';
							messageEl.className = 'comment-message';
						}

						try {
							const res = await fetch('/api/comments', {
								method: 'POST',
								headers: { 'Content-Type': 'application/json' },
								body: JSON.stringify({
									slug,
									author: authorEl?.value || '',
									content: contentEl.value,
								}),
							});

							if (res.ok) {
								if (messageEl) {
									messageEl.textContent = '¡Comentario publicado con éxito!';
									messageEl.className = 'comment-message success';
								}
								if (contentEl) contentEl.value = '';
								if (authorEl) authorEl.value = '';
								// Recargar la lista de comentarios
								await loadComments();
							} else {
								const data = await res.json();
								if (messageEl) {
									messageEl.textContent = data.error || 'Error al enviar el comentario.';
									messageEl.className = 'comment-message error';
								}
							}
						} catch (err) {
							if (messageEl) {
								messageEl.textContent = 'Error de conexión. Inténtalo de nuevo.';
								messageEl.className = 'comment-message error';
							}
						} finally {
							if (submitBtn) {
								submitBtn.disabled = false;
								submitBtn.textContent = 'Enviar comentario';
							}
						}
					});
				}

				// Carga inicial al montar la página
				loadComments();
			}
		</script>
	</body>
</html>
