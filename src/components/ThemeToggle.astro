<button id="theme-toggle" class="theme-toggle" aria-label="Toggle light/dark theme" title="Toggle theme">
	<svg class="sun-and-moon" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24">
		<mask class="moon" id="moon-mask">
			<circle cx="12" cy="12" r="9" fill="white" />
			<circle cx="18" cy="10" r="9" fill="black" />
		</mask>
		<circle class="sun" cx="12" cy="12" r="6" mask="url(#moon-mask)" fill="currentColor" />
		<g class="sun-beams" stroke="currentColor">
			<line x1="12" y1="1" x2="12" y2="3" />
			<line x1="12" y1="21" x2="12" y2="23" />
			<line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
			<line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
			<line x1="1" y1="12" x2="3" y2="12" />
			<line x1="21" y1="12" x2="23" y2="12" />
			<line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
			<line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
		</g>
	</svg>
</button>

<script>
	const initThemeToggle = () => {
		const toggle = document.getElementById("theme-toggle");
		if (!toggle) return;

		toggle.addEventListener("click", () => {
			const element = document.documentElement;
			element.classList.toggle("dark");

			const isDark = element.classList.contains("dark");
			localStorage.setItem("theme", isDark ? "dark" : "light");
		});
	};

	// Initialize on load
	initThemeToggle();

	// Support view transition navigations
	document.addEventListener("astro:after-swap", initThemeToggle);
</script>

<style>
	.theme-toggle {
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		outline-offset: 4px;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--text-color);
		transition: background-color 0.3s, color 0.3s, transform 0.2s;
	}

	.theme-toggle:hover {
		background-color: rgba(var(--gray), 15%);
		transform: scale(1.08);
	}

	.theme-toggle:active {
		transform: scale(0.95);
	}

	.sun-and-moon > :is(.sun, .sun-beams, .moon) {
		transform-origin: center;
		transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
					opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.sun-and-moon > .sun-beams {
		stroke: currentColor;
		stroke-width: 2px;
		stroke-linecap: round;
	}

	/* Dark theme SVG positioning and transitions */
	:global(html.dark) .sun-and-moon > .sun {
		transform: scale(1.75);
		transition-duration: 0.25s;
	}

	:global(html.dark) .sun-and-moon > .sun-beams {
		opacity: 0;
		transform: rotate(-45deg);
		transition-duration: 0.15s;
	}

	:global(html.dark) .sun-and-moon > mask > circle:last-child {
		transform: translate(-9px, -3px);
		transition: transform 0.25s cubic-bezier(0, 0, 0, 1);
	}

	/* Transitions for returning to light mode */
	.sun-and-moon > mask > circle:last-child {
		transform: translate(0, 0);
		transition: transform 0.25s cubic-bezier(0, 0, 0, 1);
	}
</style>
