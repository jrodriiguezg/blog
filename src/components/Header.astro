---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<h2>
			<a href="/">
				jrodriiguezg<span class="logo-dot">.</span>link
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">Sobre mí</HeaderLink>
		</div>
		<div class="right-section">
			<div class="social-links">
				<a href="https://www.instagram.com/jrodriiguezg.link/?hl=es" target="_blank" rel="noopener noreferrer">
					<span class="sr-only">Instagram</span>
