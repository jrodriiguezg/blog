					</svg>
				</a>
				<a href="https://huggingface.co/jrodriiguezg" target="_blank" rel="noopener noreferrer">
					<span class="sr-only">Hugging Face</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24" fill="currentColor">
						<path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zm-3-11.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm6 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm-6.75 4a3.75 3.75 0 0 0 7.5 0h-7.5z"></path>
					</svg>
				</a>
				<a href="https://github.com/jrodriiguezg" target="_blank" rel="noopener noreferrer">
					<span class="sr-only">GitHub</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24" fill="currentColor">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
					</svg>
				</a>
			</div>
			<ThemeToggle />
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--header-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid rgba(var(--gray), 15%);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--title-color);
		transition: color 0.3s ease;
		letter-spacing: -0.02em;
		font-weight: 700;
	}
	.logo-dot {
		color: #2337ff;
		text-shadow: 0 0 8px rgba(35, 55, 255, 0.8), 0 0 20px rgba(35, 55, 255, 0.4);
		font-weight: 900;
		transition: color 0.3s ease, text-shadow 0.3s ease;
		display: inline-block;
	}
	:global(html.dark) .logo-dot {
		color: #58a6ff;
		text-shadow: 0 0 8px rgba(88, 166, 255, 0.9), 0 0 20px rgba(88, 166, 255, 0.5);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--text-color);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		transition: color 0.3s ease, border-color 0.3s ease;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
		color: var(--title-color);
	}
	.right-section {
		display: flex;
		align-items: center;
		gap: 1.25em;
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.social-links a {
		color: var(--text-color);
		transition: color 0.3s ease;
		padding: 0.5em;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
