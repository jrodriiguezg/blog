---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../../consts';
import FormattedDate from '../../../components/FormattedDate.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const uniqueTags = Array.from(
		new Set(posts.flatMap((post) => post.data.tags || []))
	);
	return uniqueTags.map((tag) => ({
		params: { tag },
		props: { tagName: tag },
	}));
}

const { tag } = Astro.params;

const allPosts = await getCollection('blog');
const posts = allPosts
	.filter((post) => post.data.tags && post.data.tags.includes(tag))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryTitles: Record<string, string> = {
	proyectos: 'Proyectos',
	divulgacion: 'Divulgación',
	miscelanea: 'Miscelánea',
	'mi-pc': 'Mi PC',
	configuraciones: 'Configuraciones',
};
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Publicaciones sobre #${tag} - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.filter-title {
				text-align: center;
				margin-bottom: 2rem;
				font-size: 1.5rem;
				color: var(--text-color);
			}
			.filter-title span {
				color: var(--accent);
				font-weight: bold;
			}
			.back-link {
				display: block;
				text-align: center;
				margin-bottom: 2rem;
				color: var(--accent);
				text-decoration: none;
			}
			.back-link:hover {
				text-decoration: underline;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: var(--title-color);
				line-height: 1.2;
			}
			.date {
				margin: 0 0 0.5rem 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.badges-row {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}
			ul li:first-child .badges-row {
				justify-content: center;
			}
			.category-badge {
				display: inline-block;
				padding: 0.2rem 0.6rem;
				font-size: 0.75rem;
				font-weight: 700;
				text-transform: uppercase;
				border-radius: 6px;
				background: rgba(var(--gray-light), 50%);
				color: var(--text-color);
				border: 1px solid rgba(var(--gray), 15%);
			}
			.category-badge.proyectos {
				background: rgba(59, 130, 246, 15%);
				color: #3b82f6;
				border-color: rgba(59, 130, 246, 30%);
			}
			.category-badge.divulgacion {
				background: rgba(16, 185, 129, 15%);
				color: #10b981;
				border-color: rgba(16, 185, 129, 30%);
			}
			.category-badge.miscelanea {
				background: rgba(107, 114, 128, 15%);
				color: #6b7280;
				border-color: rgba(107, 114, 128, 30%);
			}
			.category-badge.mi-pc {
				background: rgba(245, 158, 11, 15%);
				color: #f59e0b;
				border-color: rgba(245, 158, 11, 30%);
			}
			.category-badge.configuraciones {
				background: rgba(139, 92, 246, 15%);
				color: #8b5cf6;
				border-color: rgba(139, 92, 246, 30%);
			}
			.tag-badge {
				font-size: 0.8rem;
				color: var(--accent);
				font-weight: 500;
			}
			.tag-badge.active-tag {
				font-weight: bold;
				background: rgba(var(--gray-light), 60%);
				padding: 0.1rem 0.4rem;
				border-radius: 4px;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: var(--accent);
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.empty-message {
				text-align: center;
				padding: 3rem;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h2 class="filter-title">Publicaciones etiquetadas con: <span>#{tag}</span></h2>
			<a href="/blog" class="back-link">&larr; Volver al blog completo</a>

			<section>
				{posts.length === 0 ? (
					<p class="empty-message">No hay publicaciones con esta etiqueta todavía.</p>
				) : (
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img width={720} height={360} src={post.data.heroImage} alt="" />
									<div class="badges-row">
										<span class={`category-badge ${post.data.category}`}>
											{categoryTitles[post.data.category] || post.data.category}
										</span>
										{post.data.tags.map((t) => (
											<span class={`tag-badge ${t === tag ? 'active-tag' : ''}`}>#{t}</span>
										))}
									</div>
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
