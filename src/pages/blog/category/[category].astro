---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../../consts';
import FormattedDate from '../../../components/FormattedDate.astro';

export async function getStaticPaths() {
	const categories = ['proyectos', 'divulgacion', 'miscelanea', 'mi-pc', 'configuraciones', 'homelab'];
	return categories.map((category) => ({
		params: { category },
		props: { categoryName: category },
	}));
}

const { category } = Astro.params;

const allPosts = await getCollection('blog');
const posts = allPosts
	.filter((post) => !post.id.startsWith('en/') && post.data.category === category)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryTitles: Record<string, string> = {
	proyectos: 'Proyectos',
	divulgacion: 'Divulgación',
	miscelanea: 'Miscelánea',
	'mi-pc': 'Mi PC',
	configuraciones: 'Configuraciones',
	homelab: 'HomeLab',
};
const displayTitle = categoryTitles[category] || category;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${displayTitle} - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.category-tabs {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin-bottom: 2.5rem;
				justify-content: center;
				padding: 0.5rem;
				background: rgba(var(--gray-light), 20%);
				border: 1px solid rgba(var(--gray), 15%);
				border-radius: 16px;
			}
			.category-tabs a {
				padding: 0.5rem 1rem;
				text-decoration: none;
				color: var(--text-color);
				border-radius: 12px;
				font-size: 0.95rem;
				font-weight: 500;
				transition: background-color 0.2s ease, color 0.2s ease;
			}
			.category-tabs a:hover {
				background: rgba(var(--gray), 15%);
				color: var(--title-color);
			}
			.category-tabs a.active {
				background: var(--accent);
				color: white;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
				justify-content: center;
			}
			ul li {
				width: calc(33.333% - 1.33rem);
				min-width: 280px;
				max-width: 360px;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				width: 100%;
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: var(--title-color);
				line-height: 1.2;
			}
			.date {
				margin: 0 0 0.5rem 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.badges-row {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}
			.category-badge {
				display: inline-block;
				padding: 0.2rem 0.6rem;
				font-size: 0.75rem;
				font-weight: 700;
				text-transform: uppercase;
				border-radius: 6px;
				background: rgba(var(--gray-light), 50%);
				color: var(--text-color);
				border: 1px solid rgba(var(--gray), 15%);
			}
			.category-badge.proyectos {
				background: rgba(59, 130, 246, 15%);
				color: #3b82f6;
				border-color: rgba(59, 130, 246, 30%);
			}
			.category-badge.divulgacion {
				background: rgba(16, 185, 129, 15%);
				color: #10b981;
				border-color: rgba(16, 185, 129, 30%);
			}
			.category-badge.miscelanea {
				background: rgba(107, 114, 128, 15%);
				color: #6b7280;
				border-color: rgba(107, 114, 128, 30%);
			}
			.category-badge.mi-pc {
				background: rgba(245, 158, 11, 15%);
				color: #f59e0b;
				border-color: rgba(245, 158, 11, 30%);
			}
			.category-badge.configuraciones {
				background: rgba(139, 92, 246, 15%);
				color: #8b5cf6;
				border-color: rgba(139, 92, 246, 30%);
			}
			.category-badge.homelab {
				background: rgba(20, 184, 166, 15%);
				color: #14b8a6;
				border-color: rgba(20, 184, 166, 30%);
			}
			.tag-badge {
				font-size: 0.8rem;
				color: var(--accent);
				font-weight: 500;
			}
			.tag-badge:hover {
				text-decoration: underline;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: var(--accent);
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.empty-message {
				text-align: center;
				padding: 3rem;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="category-tabs">
				<a href="/">Todos</a>
				<a href="/blog/category/proyectos" class={category === "proyectos" ? "active" : ""}>Proyectos</a>
				<a href="/blog/category/divulgacion" class={category === "divulgacion" ? "active" : ""}>Divulgación</a>
				<a href="/blog/category/miscelanea" class={category === "miscelanea" ? "active" : ""}>Miscelánea</a>
				<a href="/blog/category/mi-pc" class={category === "mi-pc" ? "active" : ""}>Mi PC</a>
				<a href="/blog/category/configuraciones" class={category === "configuraciones" ? "active" : ""}>Configuraciones</a>
				<a href="/blog/category/homelab" class={category === "homelab" ? "active" : ""}>HomeLab</a>
			</div>

			<section>
				{posts.length === 0 ? (
					<p class="empty-message">No hay publicaciones en esta categoría todavía.</p>
				) : (
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img width={720} height={360} src={post.data.heroImage} alt="" />
									<div class="badges-row">
										<span class={`category-badge ${post.data.category}`}>
											{categoryTitles[post.data.category] || post.data.category}
										</span>
										{post.data.tags.map((tag) => (
											<span class="tag-badge">#{tag}</span>
										))}
									</div>
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
